{
  "name": "konviw",
  "version": "3.50.5",
  "description": "Enterprise viewer for your Confluence pages",
  "author": "Jose Gascon",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.22.0"
  },
  "main": "src/main.ts",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "npm run prebuild && npm run scss && nest build",
    "deploy:vercel": "npm run build && vercel deploy --prod",
    "start": "nest start",
    "start:dev:nest": "nest start --watch",
    "start:dev:scss": "npm run scss -- --watch",
    "start:dev": "run-p start:dev:nest start:dev:scss",
    "dev": "npm run start:dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings 3",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix --max-warnings 3",
    "test": "npm run test:unit:cov",
    "test:unit:watch": "jest --config jest-unit.config.js --watch",
    "test:unit:cov": "jest --config jest-unit.config.js --coverage",
    "test:unit:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config jest-e2e.json --runInBand --forceExit",
    "scss": "sass ./src/assets/scss:dist/static/css/ --style compressed --no-source-map",
    "cypress:run": "cypress run --headless --browser chrome",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "axios": "^1.13.0",
    "cache-manager": "^6.0.0",
    "cheerio": "1.0.0-rc.10",
    "class-transformer": "0.5.1",
    "class-validator": "^0.14.4",
    "css-select": "5.1.0",
    "date-fns": "^2.30.0",
    "hbs": "4.2.0",
    "https-proxy-agent": "^5.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "4.3.0",
    "tabletojson": "2.0.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@types/express": "4.17.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.13",
    "@types/superagent": "4.1.15",
    "@types/supertest": "2.0.11",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cypress": "^15.11.0",
    "cypress-image-diff-js": "^2.5.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jest": "^28.8.0",
    "eslint-plugin-prettier": "4.2.1",
    "iframe-resizer": "4.3.2",
    "jest": "^29.7.0",
    "npm-run-all2": "^8.0.0",
    "prettier": "^3.8.3",
    "rimraf": "3.0.2",
    "sass": "1.49.9",
    "supertest": "6.2.2",
    "ts-jest": "^29.2.0",
    "ts-loader": "9.2.8",
    "ts-node": "10.7.0",
    "tsconfig-paths": "3.14.1",
    "typescript": "~5.6.0",
    "webpack": "5.106.2"
  },
  "overrides": {
    "webpack": "5.106.2",
    "file-type": "^21.3.1"
  },
  "jest": {
    "setupFiles": [
      "./setup.ts"
    ],
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "tests",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
